# Server Configuration
NODE_ENV=development
ENVIRONMENT=development
DEBUG=false

# Model Configuration
MODEL_NAME=facebook/bart-large-cnn
DEVICE=cuda
MAX_LENGTH=150
MIN_LENGTH=30

# Text Processing
MAX_INPUT_LENGTH=1024
MIN_INPUT_LENGTH=10

# Model Inference
NUM_BEAMS=4
TEMPERATURE=0.7
EARLY_STOPPING=true

# Logging
LOG_LEVEL=INFO
LOGS_DIR=./logs

# Cache Settings
CACHE_MODELS=true
MODEL_CACHE_DIR=./models/checkpoints
